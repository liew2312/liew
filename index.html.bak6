<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
<meta name="theme-color" content="#921C1E">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="ตรวจบ้าน AP">
<meta name="description" content="เครื่องมือวิศวกรโครงการ (SE) บันทึก defect และออกรายงานตรวจรับ/ปรับปรุงบ้าน — ใช้งานออฟไลน์ ข้อมูลเก็บในเครื่อง">
<link rel="manifest" href="manifest.webmanifest">
<link rel="apple-touch-icon" href="icon-192.png">
<title>ตรวจ &amp; ปรับปรุงบ้าน AP</title>
<style>
/* ── AP Thailand type (falls back gracefully if fonts/ folder is absent) ── */
@font-face{ font-family:"AP"; src:url("fonts/AP-Light300.ttf") format("truetype"); font-weight:300; font-style:normal; font-display:swap; }
@font-face{ font-family:"AP"; src:url("fonts/AP-Regular400.ttf") format("truetype"); font-weight:400; font-style:normal; font-display:swap; }
@font-face{ font-family:"AP"; src:url("fonts/AP-Medium500.ttf") format("truetype"); font-weight:500; font-style:normal; font-display:swap; }
@font-face{ font-family:"AP"; src:url("fonts/AP-Bold700.ttf") format("truetype"); font-weight:700; font-style:normal; font-display:swap; }

:root{
  --ap-red-900:#5A0B0C; --ap-red-800:#6E1214; --ap-red-700:#811618; --ap-red-600:#921C1E;
  --ap-red-500:#A62224; --ap-red-100:#F3D4D4; --ap-red-50:#FAEBEB;
  --ap-ink-900:#0A0A0D; --ap-ink-800:#131317; --ap-ink-700:#1E1E24; --ap-ink-500:#4A4A52;
  --ap-ink-400:#70707A; --ap-ink-300:#9C9CA4;
  --ap-neutral-0:#FFFFFF; --ap-neutral-100:#F8F7F3; --ap-neutral-200:#F0EEE8;
  --ap-neutral-300:#E4E1D8; --ap-neutral-400:#C9C6BC; --ap-neutral-500:#A09E94;
  --success:#2F7A4F; --success-bg:#E7F1EA; --warning:#9B6612; --warning-bg:#F7EFD8;
  --info:#2C6E9B; --info-bg:#E7F0F6;
  --border-subtle:var(--ap-neutral-300); --border-default:var(--ap-neutral-400);
  --fg-1:var(--ap-ink-800); --fg-2:var(--ap-ink-500); --fg-3:var(--ap-ink-400);
  --font-sans:"AP","Helvetica Neue","Noto Sans Thai",system-ui,-apple-system,sans-serif;
  --shadow-sm:0 1px 2px rgba(20,14,14,.04), 0 1px 3px rgba(20,14,14,.05);
  --shadow-md:0 6px 18px rgba(20,14,14,.09);
  --shadow-lg:0 -12px 38px rgba(20,14,14,.18);
  --safe-t:env(safe-area-inset-top); --safe-b:env(safe-area-inset-bottom);
}

*{ box-sizing:border-box; }
html,body{ margin:0; padding:0; height:100%; }
body{
  background:var(--ap-neutral-200);
  font-family:var(--font-sans); color:var(--fg-1);
  -webkit-tap-highlight-color:transparent; overscroll-behavior:none;
  -webkit-text-size-adjust:100%; text-size-adjust:100%;
}
button, input, textarea{ font-family:inherit; color:inherit; }
img{ max-width:100%; display:block; }

/* full-bleed app shell that always fits the viewport height */
#app{ height:100dvh; height:100svh; }
.app-shell{
  position:relative; height:100dvh; height:100svh;
  width:100%; max-width:520px; margin:0 auto;
  background:var(--ap-neutral-100); overflow:hidden;
}
@media (min-width:521px){ .app-shell{ box-shadow:0 0 0 1px var(--ap-neutral-300); } }

.screen{ height:100%; display:flex; flex-direction:column; }
.scroll{ flex:1 1 auto; overflow-y:auto; -webkit-overflow-scrolling:touch; background:var(--ap-neutral-100); }
.scroll::-webkit-scrollbar{ width:0; }

.tapopt{ cursor:pointer; user-select:none; -webkit-user-select:none; transition:transform .12s ease, background .12s ease, border-color .12s ease, box-shadow .12s ease; }
.tapopt:active{ transform:scale(.98); }

/* top bar — bold AP-red hero surface */
.topbar{ flex:0 0 auto; background:var(--ap-red-600); color:#fff; border-bottom:none;
  padding:calc(14px + var(--safe-t)) 16px 16px; box-shadow:var(--shadow-md); position:relative; z-index:2; }
.topbar-row{ display:flex; align-items:center; gap:10px; min-height:34px; }
.back-link{ display:inline-flex; align-items:center; gap:4px; color:#fff; font-size:14px; font-weight:600; min-width:0; }
.back-link span{ overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.icon-btn{ width:38px; height:38px; border-radius:999px; display:flex; align-items:center; justify-content:center; flex-shrink:0; background:rgba(255,255,255,.16); color:#fff; border:1px solid rgba(255,255,255,.34); }
.icon-btn:active{ background:rgba(255,255,255,.30); }
.topbar h1{ font-size:28px; font-weight:700; letter-spacing:-.015em; margin:12px 0 0; line-height:1.12; color:#fff; }
.topbar .sub{ font-size:13px; color:rgba(255,255,255,.82); margin-top:3px; }
.topbar .eyebrow{ font-size:12.5px; letter-spacing:.06em; text-transform:uppercase; color:rgba(255,255,255,.8); font-weight:700; }

.stat-row{ display:flex; gap:8px; margin-top:16px; }
.stat{ flex:1; background:var(--ap-neutral-100); border:1px solid var(--border-subtle); border-radius:14px; padding:10px 12px; }
.stat b{ display:block; font-size:20px; font-weight:800; font-variant-numeric:tabular-nums; line-height:1; }
.stat span{ font-size:11px; color:var(--fg-2); margin-top:3px; display:block; }
.stat-blue{ background:var(--info-bg); border-color:transparent; } .stat-blue b{ color:var(--info); }
.stat-red{ background:var(--ap-red-50); border-color:transparent; } .stat-red b{ color:var(--ap-red-600); }
.stat-green{ background:var(--success-bg); border-color:transparent; } .stat-green b{ color:var(--success); }

/* KPI cards — soft colour-coded tiles */
.kpi{ flex:1; border-radius:14px; padding:13px 6px; text-align:center; border:1px solid transparent; }
.kpi b{ display:block; font-size:22px; font-weight:800; font-variant-numeric:tabular-nums; line-height:1; }
.kpi span{ font-size:11px; font-weight:600; margin-top:5px; display:block; }
.kpi-all{ background:#fff; border-color:var(--border-subtle); } .kpi-all b{ color:var(--fg-1); } .kpi-all span{ color:var(--fg-2); }
.kpi-red{ background:var(--ap-red-50); } .kpi-red b{ color:var(--ap-red-600); } .kpi-red span{ color:var(--ap-red-700); }
.kpi-amber{ background:var(--warning-bg); } .kpi-amber b{ color:var(--warning); } .kpi-amber span{ color:var(--warning); }
.kpi-green{ background:var(--success-bg); } .kpi-green b{ color:var(--success); } .kpi-green span{ color:var(--success); }

.fld{ width:100%; font-family:var(--font-sans); font-size:16px; color:var(--fg-1); background:#fff;
  border:1px solid var(--border-default); border-radius:12px; padding:12px 14px; outline:none; }
.fld:focus{ border-color:var(--ap-red-600); box-shadow:0 0 0 3px rgba(146,28,30,.12); }
textarea.fld{ resize:none; line-height:1.45; }
.field-label{ font-size:13px; font-weight:700; margin-bottom:7px; color:var(--fg-1); }

.chip{ font-size:13px; font-weight:500; padding:8px 14px; border-radius:999px; background:#fff; color:var(--fg-1);
  border:1px solid var(--border-default); display:inline-flex; align-items:center; gap:6px; }
.chip.is-active{ background:var(--ap-red-600); color:#fff; border-color:var(--ap-red-600); font-weight:600; }
.chip-row{ display:flex; gap:8px; flex-wrap:wrap; }

.sev-chip{ flex:1; text-align:center; font-size:13px; font-weight:600; padding:11px 4px; border-radius:12px; background:#fff; border:1.5px solid var(--border-default); color:var(--fg-2); }
.sev-chip.is-active[data-value="high"]{ background:var(--ap-red-50); color:var(--ap-red-600); border-color:var(--ap-red-600); }
.sev-chip.is-active[data-value="mid"]{ background:var(--warning-bg); color:var(--warning); border-color:var(--warning); }
.sev-chip.is-active[data-value="low"]{ background:var(--ap-neutral-200); color:var(--fg-2); border-color:var(--ap-neutral-500); }
.st-chip{ flex:1; text-align:center; font-size:13px; font-weight:600; padding:11px 4px; border-radius:12px; background:#fff; border:1.5px solid var(--border-default); color:var(--fg-2); }
.st-chip.is-active[data-value="open"]{ background:var(--ap-red-50); color:var(--ap-red-600); border-color:var(--ap-red-600); }
.st-chip.is-active[data-value="prog"]{ background:var(--warning-bg); color:var(--warning); border-color:var(--warning); }
.st-chip.is-active[data-value="done"]{ background:var(--success-bg); color:var(--success); border-color:var(--success); }

/* worksheet mode selector — red (handover) vs ink (stock), no third colour */
.mode-card{ border:1.5px solid var(--border-default); background:#fff; border-radius:14px; padding:14px 15px; display:flex; gap:12px; align-items:flex-start; }
.mode-card .dot{ width:22px; height:22px; border-radius:999px; border:2px solid var(--ap-neutral-400); flex-shrink:0; margin-top:1px; display:flex; align-items:center; justify-content:center; }
.mode-card .dot span{ width:11px; height:11px; border-radius:999px; background:transparent; }
.mode-card.is-active[data-value="handover"]{ border-color:var(--ap-red-600); background:var(--ap-red-50); }
.mode-card.is-active[data-value="handover"] .dot{ border-color:var(--ap-red-600); }
.mode-card.is-active[data-value="handover"] .dot span{ background:var(--ap-red-600); }
.mode-card.is-active[data-value="handover"] .mode-title{ color:var(--ap-red-600); }
.mode-card.is-active[data-value="stock"]{ border-color:var(--ap-ink-800); background:var(--ap-neutral-200); }
.mode-card.is-active[data-value="stock"] .dot{ border-color:var(--ap-ink-800); }
.mode-card.is-active[data-value="stock"] .dot span{ background:var(--ap-ink-800); }
.mode-card.is-active[data-value="stock"] .mode-title{ color:var(--ap-ink-800); }
.mode-title{ font-size:15px; font-weight:700; color:var(--fg-1); }
.mode-desc{ font-size:12.5px; color:var(--fg-2); margin-top:2px; line-height:1.4; }

.tag{ font-size:11px; font-weight:700; padding:4px 10px; border-radius:999px; white-space:nowrap; }
.tag-handover{ background:var(--ap-red-50); color:var(--ap-red-700); }
.tag-stock{ background:var(--info-bg); color:var(--info); }

.btn-primary{ background:var(--ap-red-600); color:#fff; border-radius:999px; height:52px; display:flex; align-items:center; justify-content:center; gap:9px; font-size:16px; font-weight:600; box-shadow:var(--shadow-md); border:none; width:100%; }
.btn-primary[disabled], .btn-primary.is-disabled{ background:var(--ap-neutral-400); box-shadow:none; }
.btn-ghost{ background:#fff; color:var(--ap-red-600); border:1.5px solid var(--ap-red-600); border-radius:999px; height:52px; display:flex; align-items:center; justify-content:center; gap:8px; font-size:15px; font-weight:600; }
.btn-outline-round{ flex-shrink:0; width:52px; height:52px; border-radius:999px; background:#fff; border:1.5px solid var(--fg-1); display:flex; align-items:center; justify-content:center; color:var(--fg-1); }

.bottom-bar{ flex:0 0 auto; padding:12px 16px calc(14px + var(--safe-b)); background:#fff; border-top:1px solid var(--border-subtle); display:flex; gap:10px; box-shadow:0 -6px 18px rgba(20,14,14,.05); }

.card{ background:#fff; border:1px solid var(--border-subtle); border-radius:16px; box-shadow:var(--shadow-sm); }
.card.tapopt:active{ box-shadow:var(--shadow-md); }
.progress-track{ flex:1; height:7px; border-radius:999px; background:var(--ap-neutral-200); overflow:hidden; }
.progress-fill{ height:100%; background:var(--ap-red-600); border-radius:999px; }

.thumb{ background-color:var(--ap-neutral-200); background-size:cover; background-position:center; display:flex; align-items:center; justify-content:center; color:var(--ap-neutral-500); }

.overlay-backdrop{ position:absolute; inset:0; background:rgba(19,19,23,.46); z-index:60; }
.overlay-sheet{ position:absolute; left:0; right:0; bottom:0; background:var(--ap-neutral-100); border-radius:24px 24px 0 0;
  padding:14px 18px calc(22px + var(--safe-b)); max-height:94%; overflow-y:auto; box-shadow:var(--shadow-lg); z-index:61; }
.sheet-grabber{ width:40px; height:5px; border-radius:999px; background:var(--ap-neutral-400); margin:0 auto 16px; }

.photo-tile{ width:74px; height:74px; border-radius:14px; background-size:cover; background-position:center; position:relative; border:1px solid var(--border-subtle); background-color:var(--ap-neutral-200); flex-shrink:0; }
.photo-remove{ position:absolute; top:-6px; right:-6px; width:22px; height:22px; border-radius:999px; background:#131317; color:#fff; display:flex; align-items:center; justify-content:center; }

.sign-box{ background:#fff; border:1px solid var(--border-subtle); border-radius:16px; padding:14px 15px; }
.sign-slot{ border:1.5px dashed var(--border-default); border-radius:12px; height:110px; display:flex; align-items:center; justify-content:center; color:var(--fg-3); font-size:13px; background:var(--ap-neutral-100); background-size:contain; background-repeat:no-repeat; background-position:center; }
.sign-slot.signed{ border-style:solid; border-color:var(--border-subtle); background-color:#fff; }
#sig-canvas{ width:100%; height:230px; background:#fff; border:1px solid var(--border-default); border-radius:12px; touch-action:none; display:block; }

.empty-state{ text-align:center; padding:40px 24px; color:var(--fg-3); font-size:14px; line-height:1.6;
  border:1.5px dashed var(--border-default); border-radius:16px; background:rgba(255,255,255,.5); margin:6px 0; }
.hidden-file-input{ position:absolute; width:1px; height:1px; opacity:0; pointer-events:none; }

@media print{ .app-shell{ display:none; } }
</style>
</head>
<body>
<div id="app"></div>
<input type="file" id="cam-input" class="hidden-file-input" accept="image/*" capture="environment">
<input type="file" id="gal-input" class="hidden-file-input" accept="image/*" multiple>
<input type="file" id="backup-input" class="hidden-file-input" accept="application/json,.json">
<script>
"use strict";
/* ============================================================
   ตรวจ & ปรับปรุงบ้าน AP — เครื่องมือวิศวกรโครงการ (SE)
   Vanilla JS · offline-first PWA · no network · no build step
   โครงสร้าง: โครงการ → แปลง → ใบงานตรวจ (stock / ก่อนโอน) → รายการ defect
   ============================================================ */

/* ---------- constants ---------- */
var LS_KEY  = 'ap_inspect_v4';
var V3_KEY  = 'ap_inspect_v3';
var V2_KEY  = 'ap_se_inspect_v2';
var MAX_PHOTOS_PER_DEFECT = 6;
var APP_VERSION = 'v10 · 2 ก.ค. 2026';

var CATS = [
  { id:'paint', name:'สี' }, { id:'tile', name:'กระเบื้อง' }, { id:'elec', name:'ไฟฟ้า' },
  { id:'plumb', name:'ประปา' }, { id:'door', name:'ประตู-หน้าต่าง' }, { id:'wood', name:'งานไม้' }, { id:'ceil', name:'ฝ้า/ผนัง' },
];
var SEV = {
  high:{ name:'ร้ายแรง', color:'#921C1E' },
  mid:  { name:'ปานกลาง', color:'#9B6612' },
  low:  { name:'เล็กน้อย', color:'#4A4A52' },
};
var STATUS = {
  open:{ name:'รอแก้', color:'#921C1E', bg:'#FAEBEB' },
  prog:{ name:'กำลังแก้', color:'#9B6612', bg:'#F6ECD6' },
  done:{ name:'แก้แล้ว', color:'#2F7A4F', bg:'#EAF2ED' },
};
var STATUS_ORDER = ['open','prog','done'];
var ROOMS = ['ห้องนั่งเล่น','ครัว','ห้องนอนใหญ่','ห้องนอน 2','ห้องน้ำ','ระเบียง','โรงจอดรถ','ภายนอก'];
var CAT_KEY='ap_cats_v1', ROOM_KEY='ap_rooms_v1';
function loadCustomLists(){
  try{ (JSON.parse(localStorage.getItem(CAT_KEY)||'[]')||[]).forEach(function(x){ if(x&&x.id&&x.name&&!CATS.some(function(k){return k.id===x.id;})) CATS.push(x); }); }catch(e){}
  try{ (JSON.parse(localStorage.getItem(ROOM_KEY)||'[]')||[]).forEach(function(x){ if(x&&ROOMS.indexOf(x)<0) ROOMS.push(x); }); }catch(e){}
}
var TYPES = ['บ้านเดี่ยว','บ้านแฝด','ทาวน์โฮม','คอนโดฯ'];

/* ---------- utils ---------- */
function uid(){ return Date.now().toString(36) + Math.random().toString(36).slice(2,8); }
function esc(t){ return String(t==null?'':t).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
function attr(t){ return esc(t); }
function styleUrl(u){ return u ? "background-image:url(" + JSON.stringify(u).replace(/"/g,"'") + ")" : ''; }
function todayStr(){ var d=new Date(); return String(d.getDate()).padStart(2,'0')+'/'+String(d.getMonth()+1).padStart(2,'0')+'/'+d.getFullYear(); }

function downscalePhoto(file){
  return new Promise(function(resolve){
    var r = new FileReader();
    r.onload = function(){
      var img = new Image();
      img.onload = function(){
        var max = 1000, w = img.width, h = img.height;
        var sc = Math.min(1, max / Math.max(w, h));
        var c = document.createElement('canvas');
        c.width = Math.max(1, Math.round(w * sc));
        c.height = Math.max(1, Math.round(h * sc));
        c.getContext('2d').drawImage(img, 0, 0, c.width, c.height);
        resolve(c.toDataURL('image/jpeg', 0.6));
      };
      img.onerror = function(){ resolve(null); };
      img.src = r.result;
    };
    r.onerror = function(){ resolve(null); };
    r.readAsDataURL(file);
  });
}

/* ---------- storage: structured data (localStorage) ---------- */
var Store = {
  load: function(key){
    try { var raw = localStorage.getItem(key||LS_KEY); return raw ? JSON.parse(raw) : null; }
    catch(e){ return null; }
  },
  save: function(projects){
    try { localStorage.setItem(LS_KEY, JSON.stringify(projects)); return true; }
    catch(e){ alert('บันทึกข้อมูลไม่สำเร็จ — พื้นที่จัดเก็บในเครื่องอาจเต็ม'); return false; }
  }
};

/* ---------- storage: photos (IndexedDB, falls back to localStorage) ---------- */
var Photos = (function(){
  var dbPromise = null;
  var FALLBACK_KEY = 'ap_inspect_photos_fallback';
  function openDB(){
    if (dbPromise) return dbPromise;
    dbPromise = new Promise(function(resolve){
      if (!('indexedDB' in window)) { resolve(null); return; }
      try {
        var req = indexedDB.open('ap_inspect_photos_db', 1);
        req.onupgradeneeded = function(){ req.result.createObjectStore('photos'); };
        req.onsuccess = function(){ resolve(req.result); };
        req.onerror = function(){ resolve(null); };
      } catch(e){ resolve(null); }
    });
    return dbPromise;
  }
  function fallbackAll(){ try { return JSON.parse(localStorage.getItem(FALLBACK_KEY) || '{}'); } catch(e){ return {}; } }
  function fallbackSave(map){ try { localStorage.setItem(FALLBACK_KEY, JSON.stringify(map)); return true; } catch(e){ return false; } }
  function put(dataUrl){
    return openDB().then(function(db){
      var id = uid();
      if (db){
        return new Promise(function(resolve){
          var tx = db.transaction('photos','readwrite');
          tx.objectStore('photos').put(dataUrl, id);
          tx.oncomplete = function(){ resolve(id); };
          tx.onerror = function(){ resolve(id); };
        });
      }
      var map = fallbackAll(); map[id] = dataUrl; fallbackSave(map);
      return id;
    });
  }
  function get(id){
    if (!id) return Promise.resolve(null);
    return openDB().then(function(db){
      if (db){
        return new Promise(function(resolve){
          var tx = db.transaction('photos','readonly');
          var req = tx.objectStore('photos').get(id);
          req.onsuccess = function(){ resolve(req.result || null); };
          req.onerror = function(){ resolve(null); };
        });
      }
      return fallbackAll()[id] || null;
    });
  }
  function del(id){
    return openDB().then(function(db){
      if (db){ try { db.transaction('photos','readwrite').objectStore('photos').delete(id); } catch(e){} return; }
      var map = fallbackAll(); delete map[id]; fallbackSave(map);
    });
  }
  function putId(id, dataUrl){
    return openDB().then(function(db){
      if (db){
        return new Promise(function(resolve){
          var tx = db.transaction('photos','readwrite');
          tx.objectStore('photos').put(dataUrl, id);
          tx.oncomplete = function(){ resolve(id); };
          tx.onerror = function(){ resolve(id); };
        });
      }
      var map = fallbackAll(); map[id] = dataUrl; fallbackSave(map);
      return id;
    });
  }
  return { put:put, putId:putId, get:get, del:del };
})();

/* ---------- migration → v4 (โครงการ → แปลง → ใบงานตรวจ → defect) ---------- */
function newSheet(mode, round, extra){
  return Object.assign({ id:uid(), mode:mode||'handover', round:round||1, date:'', inspector:'',
    note:'', defects:[], sigSE:null, sigSEName:'', sigCust:null, sigCustName:'', createdAt:Date.now() }, extra||{});
}
function migrate(){
  var v4 = Store.load(LS_KEY);
  if (v4 && v4.length) return Promise.resolve(v4);

  // v3: mode was on the project; units held defects directly
  var v3 = Store.load(V3_KEY);
  if (v3 && v3.length){
    var out3 = v3.map(function(p){
      return {
        id:p.id||uid(), name:p.name||'', details:p.details||'', type:p.type||TYPES[0], createdAt:p.createdAt||Date.now(),
        units:(p.units||[]).map(function(u){
          var sheet = newSheet(p.mode||'handover', 1, { date:u.appt||'', defects:u.defects||[] });
          return { id:u.id||uid(), code:u.code||'', customer:u.customer||'', note:u.note||'', createdAt:u.createdAt||Date.now(), sheets:[sheet] };
        })
      };
    });
    Store.save(out3);
    return Promise.resolve(out3);
  }

  // v2: old prototype demo (photos as inline urls) → build v4 + push photos to IndexedDB
  var v2 = Store.load(V2_KEY);
  if (v2 && v2.length){
    var chain = Promise.resolve(); var out2 = [];
    v2.forEach(function(p){
      var np = { id:p.id||uid(), name:p.name||'', details:'', type:p.type||TYPES[0], createdAt:Date.now(), units:[] };
      out2.push(np);
      (p.units||[]).forEach(function(u){
        var sh = newSheet(p.mode||'handover', 1, { date:u.appt||'' });
        var nu = { id:u.id||uid(), code:u.code||'', customer:u.customer||'', note:u.note||'', createdAt:Date.now(), sheets:[sh] };
        np.units.push(nu);
        (u.defects||[]).forEach(function(d){
          var nd = { id:d.id||uid(), room:d.room||ROOMS[0], cat:d.cat||CATS[0].id, sev:d.sev||'mid', status:d.status||'open', note:d.note||'', photoIds:[], time:d.time||'', createdAt:Date.now() };
          sh.defects.push(nd);
          (d.photos||[]).forEach(function(url){ chain = chain.then(function(){ return Photos.put(url); }).then(function(id){ nd.photoIds.push(id); }); });
        });
      });
    });
    return chain.then(function(){ Store.save(out2); return out2; });
  }
  return Promise.resolve([]);
}

/* ---------- in-memory state ---------- */
var projects = [];
var photoUrlCache = new Map();
var pendingPhotos = [];      /* [{url, photoId|null}] "before" photos while the defect sheet is open */
var pendingPhotosAfter = []; /* [{url, photoId|null}] "after fix" photos */
var sigPad = null;           /* active signature pad controller */

var state = {
  screen: 'projects',        /* projects | project | unit | sheet | deflist */
  curP:null, curU:null, curS:null,
  overlay:null,              /* null | project | unit | sheet | defect | signature */
  formMode:'add', editId:null,
  formType:TYPES[0], formSheetMode:'handover',
  formCat:CATS[0].id, formSev:'mid', formRoom:ROOMS[0],
  sigRole:'se', photoTarget:'before', formNoteDraft:'', formStatus:'open',
};

/* ---------- data helpers ---------- */
function findProject(pid){ return projects.find(function(p){ return p.id===pid; }) || null; }
function findUnit(p, uidv){ return p ? (p.units.find(function(u){ return u.id===uidv; }) || null) : null; }
function findSheet(u, sid){ return u ? (u.sheets.find(function(s){ return s.id===sid; }) || null) : null; }
function findDefect(s, did){ return s ? (s.defects.find(function(d){ return d.id===did; }) || null) : null; }
function persist(){ Store.save(projects); }

function modeMeta(mode){
  return mode === 'stock'
    ? { label:'ปรับปรุง Stock', tag:'tag-stock', work:'งานปรับปรุงบ้าน Stock' }
    : { label:'ตรวจก่อนโอน', tag:'tag-handover', work:'งานส่งมอบลูกค้า' };
}
function secondSignerLabel(mode){ return mode==='stock' ? 'ผู้จัดการโครงการ (PM)' : 'ลูกค้า / ผู้รับมอบ'; }
function catName(id){ var c = CATS.find(function(x){ return x.id===id; }); return c ? c.name : id; }

/* counts */
function sheetDefects(s){ return s.defects || []; }
function unitDefects(u){ var a=[]; (u.sheets||[]).forEach(function(s){ a=a.concat(s.defects||[]); }); return a; }
function projDefects(p){ var a=[]; (p.units||[]).forEach(function(u){ a=a.concat(unitDefects(u)); }); return a; }
function openOf(list){ return list.filter(function(d){ return d.status!=='done'; }).length; }
function progressOf(list){ if(!list.length) return 0; var d=list.filter(function(x){return x.status==='done';}).length; return Math.round(d/list.length*100); }
function unitSheetCount(u){ return (u.sheets||[]).length; }

function sheetTitle(s){ return 'ใบงานตรวจ ครั้งที่ ' + (s.round||1); }
function sheetStatusMeta(s){
  var ds = sheetDefects(s);
  if (!ds.length) return { label:'ยังไม่บันทึก', color:'#4A4A52', bg:'#F0EEE8' };
  return openOf(ds) ? { label:'มี defect', color:'#921C1E', bg:'#FAEBEB' } : { label:'ครบแล้ว', color:'#2F7A4F', bg:'#EAF2ED' };
}

/* ---------- render root ---------- */
function render(){
  var root = document.getElementById('app');
  root.innerHTML = renderApp();
  hydrateLazyPhotos(root);
  if (state.overlay === 'signature') initSignaturePad();
}
function hydrateLazyPhotos(container){
  container.querySelectorAll('[data-lazy-photo]').forEach(function(el){
    var id = el.getAttribute('data-lazy-photo');
    if (photoUrlCache.has(id)){ el.style.backgroundImage = "url("+photoUrlCache.get(id)+")"; el.removeAttribute('data-lazy-photo'); return; }
    Photos.get(id).then(function(url){ if (url){ photoUrlCache.set(id,url); el.style.backgroundImage="url("+url+")"; } el.removeAttribute('data-lazy-photo'); });
  });
}
function renderApp(){
  var screenHtml = '';
  if (state.screen==='projects') screenHtml = renderProjectsScreen();
  else if (state.screen==='project') screenHtml = renderProjectScreen();
  else if (state.screen==='unit') screenHtml = renderUnitScreen();
  else if (state.screen==='sheet') screenHtml = renderSheetScreen();
  else if (state.screen==='deflist') screenHtml = renderDefectListScreen();

  var overlayHtml = '';
  if (state.overlay==='project') overlayHtml = renderProjectOverlay();
  else if (state.overlay==='unit') overlayHtml = renderUnitOverlay();
  else if (state.overlay==='sheet') overlayHtml = renderSheetOverlay();
  else if (state.overlay==='defect') overlayHtml = renderDefectOverlay();
  else if (state.overlay==='signature') overlayHtml = renderSignatureOverlay();
  else if (state.overlay==='settings') overlayHtml = renderSettingsOverlay();

  return '<div class="app-shell">' + screenHtml + overlayHtml + '</div>';
}
function iconBtn(action, extra, path){
  return '<span class="tapopt icon-btn" data-action="'+action+'"'+(extra||'')+'>' +
    '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9">'+path+'</svg></span>';
}
var IC_EDIT='<path d="M12 20h9"></path><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>';
var IC_HOME='<path d="M3 10.5 12 3l9 7.5"></path><path d="M5 9.5V20a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9.5"></path>';
var IC_PDF='<path d="M14 3v5h5"></path><path d="M14 3H6a1 1 0 0 0-1 1v16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V8Z"></path><path d="M9 13h6M9 17h4"></path>';
var IC_PLUS='<path d="M12 5v14M5 12h14"></path>';
var IC_BACK='<path d="m15 18-6-6 6-6"></path>';
var IC_GEAR='<circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>';

/* ---------- screen: projects (home) ---------- */
function renderProjectsScreen(){
  var body;
  if (!projects.length){
    body = '<div class="empty-state">' +
      '<svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" style="margin-bottom:14px;"><path d="M3 21V8l9-5 9 5v13"></path><path d="M9 21v-6h6v6"></path></svg>' +
      '<div>ยังไม่มีโครงการ<br>กดปุ่มด้านล่างเพื่อเพิ่มโครงการแรก</div></div>';
  } else {
    body = '<div style="display:flex;flex-direction:column;gap:12px;">' + projects.map(function(p){
      var ds = projDefects(p), prog = progressOf(ds), open = openOf(ds), total = ds.length;
      var openLabel = open>0 ? (open+' รอแก้') : (total>0 ? 'ครบแล้ว' : 'ยังไม่เริ่ม');
      return '<div class="card tapopt" data-action="open-project" data-id="'+attr(p.id)+'" style="padding:16px;">' +
        '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">' +
          '<div><div style="font-size:18px;font-weight:700;letter-spacing:-.01em;">'+esc(p.name)+'</div>' +
          '<div style="font-size:13px;color:var(--fg-2);margin-top:2px;">'+esc(p.type)+'</div></div>' +
        '</div>' +
        '<div style="display:flex;align-items:center;gap:10px;margin-top:14px;">' +
          '<div class="progress-track"><div class="progress-fill" style="width:'+prog+'%;"></div></div>' +
          '<span style="font-size:12px;color:var(--fg-3);font-variant-numeric:tabular-nums;">'+prog+'%</span></div>' +
        '<div style="display:flex;gap:16px;margin-top:12px;font-size:13px;">' +
          '<span style="color:var(--fg-2);">แปลง <b style="color:var(--fg-1);">'+p.units.length+'</b></span>' +
          '<span style="color:var(--fg-2);">defect <b style="color:var(--fg-1);">'+total+'</b></span>' +
          '<span style="color:var(--ap-red-600);font-weight:600;margin-left:auto;">'+esc(openLabel)+'</span>' +
        '</div></div>';
    }).join('') + '</div>';
  }
  return '<div class="screen">' +
    '<div class="topbar">' +
      '<div class="topbar-row"><div class="eyebrow" style="flex:1;">AP · วิศวกรโครงการ</div>' +
        iconBtn('open-settings','',IC_GEAR) + '</div>' +
      '<h1>โครงการของฉัน</h1></div>' +
    '<div class="scroll" style="padding:16px;">'+body+'</div>' +
    '<div class="bottom-bar"><button type="button" class="btn-primary tapopt" data-action="open-overlay-project" data-mode="add">' +
      '<svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">'+IC_PLUS+'</svg>เพิ่มโครงการ</button></div>' +
  '</div>';
}

/* ---------- screen: project (list of แปลง) ---------- */
function renderProjectScreen(){
  var P = findProject(state.curP);
  if (!P){ state.screen='projects'; return renderProjectsScreen(); }
  var ds = projDefects(P);
  var body;
  if (!P.units.length){
    body = '<div class="empty-state">ยังไม่มีแปลง — กด “เพิ่มแปลง” ด้านล่าง</div>';
  } else {
    body = '<div style="display:flex;flex-direction:column;gap:12px;">' + P.units.map(function(u){
      var uds = unitDefects(u), open = openOf(uds);
      var openLabel = open>0 ? (open+' รอแก้') : (uds.length>0 ? 'ครบแล้ว' : 'ยังไม่ตรวจ');
      return '<div class="card tapopt" data-action="open-unit" data-id="'+attr(u.id)+'" style="padding:15px 16px;">' +
        '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">' +
          '<div style="min-width:0;"><div style="font-size:17px;font-weight:700;">'+(u.plot?'แปลง '+esc(u.plot)+' · ':'')+'บ้านเลขที่ '+esc(u.code)+'</div>' +
          '<div style="font-size:13px;color:var(--fg-2);margin-top:1px;">'+(u.model?'แบบ '+esc(u.model)+' · ':'')+esc(u.customer || 'ยังไม่ระบุลูกค้า')+'</div></div>' +
          '<span class="tag tag-stock">'+unitSheetCount(u)+' ใบงาน</span>' +
        '</div>' +
        '<div style="display:flex;gap:16px;margin-top:12px;font-size:13px;">' +
          '<span style="color:var(--fg-2);">defect <b style="color:var(--fg-1);">'+uds.length+'</b></span>' +
          '<span style="color:var(--ap-red-600);font-weight:600;">'+esc(openLabel)+'</span></div></div>';
    }).join('') + '</div>';
  }
  var detailsHtml = P.details ? '<div class="sub" style="margin-top:6px;">'+esc(P.details)+'</div>' : '';
  return '<div class="screen">' +
    '<div class="topbar">' +
      '<div class="topbar-row">' +
        '<span class="tapopt back-link" data-action="back-projects" style="flex:1;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">'+IC_BACK+'</svg><span>โครงการ</span></span>' +
        iconBtn('open-overlay-project',' data-mode="edit" data-id="'+attr(P.id)+'"',IC_EDIT) +
        iconBtn('back-projects','',IC_HOME) +
      '</div>' +
      '<h1>'+esc(P.name)+'</h1>' +
      '<div class="sub">'+esc(P.type)+'</div>' + detailsHtml +
      '<div class="stat-row">' +
        '<div class="stat stat-blue"><b>'+P.units.length+'</b><span>แปลง</span></div>' +
        '<div class="stat stat-red"><b>'+openOf(ds)+'</b><span>defect รอแก้</span></div>' +
        '<div class="stat stat-green"><b>'+progressOf(ds)+'%</b><span>คืบหน้า</span></div>' +
      '</div>' +
    '</div>' +
    '<div class="scroll" style="padding:16px;"><div style="font-size:15px;font-weight:700;margin-bottom:12px;">แปลง / บ้าน</div>'+body+'</div>' +
    '<div class="bottom-bar">' +
      '<button type="button" class="btn-primary tapopt" data-action="open-overlay-unit" data-mode="add"><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">'+IC_PLUS+'</svg>เพิ่มแปลง</button>' +
    '</div></div>';
}

/* ---------- screen: unit (list of ใบงานตรวจ) ---------- */
function renderUnitScreen(){
  var P = findProject(state.curP), U = findUnit(P, state.curU);
  if (!P || !U){ state.screen='project'; return renderProjectScreen(); }
  var body;
  if (!U.sheets.length){
    body = '<div class="empty-state">ยังไม่มีใบงานตรวจ<br>กด “เพิ่มใบงานตรวจ” แล้วเลือกประเภทงาน</div>';
  } else {
    body = '<div style="display:flex;flex-direction:column;gap:12px;">' + U.sheets.slice().sort(function(a,b){ return (a.round||0)-(b.round||0); }).map(function(s){
      var mm = modeMeta(s.mode), sm = sheetStatusMeta(s), ds = sheetDefects(s);
      return '<div class="card tapopt" data-action="open-sheet" data-id="'+attr(s.id)+'" style="padding:15px 16px;">' +
        '<div style="display:flex;justify-content:space-between;align-items:center;gap:10px;">' +
          '<div style="font-size:16px;font-weight:700;">ครั้งที่ '+(s.round||1)+'</div>' +
          '<div style="display:flex;align-items:center;gap:12px;">' +
            '<span class="tag '+mm.tag+'">'+esc(mm.label)+'</span>' +
            '<span class="tapopt" data-action="open-overlay-sheet" data-mode="edit" data-id="'+attr(s.id)+'" style="color:var(--fg-2);display:inline-flex;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9">'+IC_EDIT+'</svg></span>' +
            '<span class="tapopt" data-action="remove-sheet" data-id="'+attr(s.id)+'" style="color:var(--fg-3);display:inline-flex;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2M6 7l1 13a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1l1-13"></path></svg></span>' +
          '</div></div>' +
        '<div style="font-size:12.5px;color:var(--fg-2);margin-top:4px;">'+(s.date?esc(s.date):'ยังไม่ระบุวันที่')+(s.inspector?' · ผู้ตรวจ '+esc(s.inspector):'')+'</div>' +
        '<div style="display:flex;align-items:center;gap:12px;margin-top:11px;font-size:13px;">' +
          '<span style="color:var(--fg-2);">defect <b style="color:var(--fg-1);">'+ds.length+'</b></span>' +
          '<span style="font-size:11.5px;font-weight:700;padding:3px 9px;border-radius:999px;background:'+sm.bg+';color:'+sm.color+';margin-left:auto;">'+esc(sm.label)+'</span></div></div>';
    }).join('') + '</div>';
  }
  return '<div class="screen">' +
    '<div class="topbar">' +
      '<div class="topbar-row">' +
        '<span class="tapopt back-link" data-action="back-project" style="flex:1;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">'+IC_BACK+'</svg><span>'+esc(P.name)+'</span></span>' +
        iconBtn('open-overlay-unit',' data-mode="edit" data-id="'+attr(U.id)+'"',IC_EDIT) +
        iconBtn('back-projects','',IC_HOME) +
      '</div>' +
      (U.plot?'<div style="font-size:15px;font-weight:700;color:rgba(255,255,255,.92);margin-bottom:2px;">แปลง '+esc(U.plot)+'</div>':'') +
      '<h1>บ้านเลขที่ '+esc(U.code)+'</h1>' +
      '<div class="sub">'+(U.model?'แบบ '+esc(U.model)+' · ':'')+esc(U.customer || 'ยังไม่ระบุลูกค้า')+(U.note?' · '+esc(U.note):'')+'</div>' +
    '</div>' +
    '<div class="scroll" style="padding:16px;"><div style="font-size:15px;font-weight:700;margin-bottom:12px;">ใบงานตรวจ ('+U.sheets.length+')</div>'+body+'</div>' +
    '<div class="bottom-bar">' +
      '<button type="button" class="btn-primary tapopt" data-action="open-overlay-sheet" data-mode="add"><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">'+IC_PLUS+'</svg>เพิ่มใบงานตรวจ</button>' +
    '</div></div>';
}

/* ---------- shared: defect list markup ---------- */
function defectListHtml(S){
  if (!S.defects.length){
    return '<div class="empty-state">ยังไม่มี defect — กด “บันทึก defect” เพื่อเริ่ม</div>';
  }
  return '<div style="display:flex;flex-direction:column;gap:12px;">' + S.defects.map(function(d, idx){
    var sev = SEV[d.sev], st = STATUS[d.status];
    var hasPhoto = d.photoIds && d.photoIds.length>0;
    var afterN = (d.photoIdsAfter && d.photoIdsAfter.length) || 0;
    var thumbAttr = hasPhoto ? ' data-lazy-photo="'+attr(d.photoIds[0])+'"' : '';
    var thumbInner = hasPhoto ? '' : '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.6"></circle><path d="m21 15-5-5L5 21"></path></svg>';
    var canUp = idx>0, canDown = idx<S.defects.length-1;
    return '<div class="card tapopt" data-action="open-overlay-defect" data-mode="edit" data-id="'+attr(d.id)+'" style="overflow:hidden;display:flex;">' +
      '<div class="thumb" style="width:80px;flex-shrink:0;"'+thumbAttr+'>'+thumbInner+'</div>' +
      '<div style="flex:1;padding:11px 13px;min-width:0;">' +
        '<div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">' +
          '<span style="font-size:13px;font-weight:700;">'+esc(catName(d.cat))+'</span>' +
          '<span class="tapopt" data-action="cycle-status" data-id="'+attr(d.id)+'" style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;background:'+st.bg+';color:'+st.color+';white-space:nowrap;">'+esc(st.name)+'</span></div>' +
        '<div style="font-size:13px;color:var(--fg-2);margin-top:5px;line-height:1.4;">'+esc(d.note)+'</div>' +
        '<div style="display:flex;align-items:center;gap:9px;margin-top:8px;flex-wrap:wrap;">' +
          '<span style="font-size:11px;font-weight:700;color:'+sev.color+';">● '+esc(sev.name)+'</span>' +
          '<span style="font-size:11.5px;color:var(--fg-3);">'+esc(d.room)+'</span>' +
          (hasPhoto && d.photoIds.length>1 ? '<span style="font-size:11px;color:var(--fg-3);">ก่อน +'+(d.photoIds.length-1)+'</span>' : '') +
          (afterN ? '<span style="font-size:11px;font-weight:700;color:#2F7A4F;">✓ หลัง '+afterN+' รูป</span>' : '') +
          '<span style="margin-left:auto;display:flex;gap:10px;">' +
            '<span class="tapopt" data-action="move-defect" data-dir="up" data-id="'+attr(d.id)+'" style="color:'+(canUp?'var(--fg-2)':'var(--ap-neutral-400)')+';display:inline-flex;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19V5M5 12l7-7 7 7"></path></svg></span>' +
            '<span class="tapopt" data-action="move-defect" data-dir="down" data-id="'+attr(d.id)+'" style="color:'+(canDown?'var(--fg-2)':'var(--ap-neutral-400)')+';display:inline-flex;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"></path></svg></span>' +
            '<span class="tapopt" data-action="remove-defect" data-id="'+attr(d.id)+'" style="color:var(--fg-3);display:inline-flex;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2M6 7l1 13a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1l1-13"></path></svg></span>' +
          '</span></div></div></div>';
  }).join('') + '</div>';
}

/* ---------- screen: sheet (summary + signatures) ---------- */
function renderSheetScreen(){
  var P = findProject(state.curP), U = findUnit(P, state.curU), S = findSheet(U, state.curS);
  if (!P || !U || !S){ state.screen='unit'; return renderUnitScreen(); }
  var mm = modeMeta(S.mode), isHandover = S.mode!=='stock';
  var ds = S.defects || [];
  var counts = { all:ds.length,
    open:ds.filter(function(d){return d.status==='open';}).length,
    prog:ds.filter(function(d){return d.status==='prog';}).length,
    done:ds.filter(function(d){return d.status==='done';}).length };

  var summary = '<div style="display:flex;gap:8px;margin-bottom:16px;">' +
    '<div class="kpi kpi-all"><b>'+counts.all+'</b><span>ทั้งหมด</span></div>' +
    '<div class="kpi kpi-red"><b>'+counts.open+'</b><span>รอแก้</span></div>' +
    '<div class="kpi kpi-amber"><b>'+counts.prog+'</b><span>กำลังแก้</span></div>' +
    '<div class="kpi kpi-green"><b>'+counts.done+'</b><span>แก้แล้ว</span></div>' +
  '</div>';

  var listLink = '<div class="card tapopt" data-action="open-deflist" style="padding:15px 16px;display:flex;align-items:center;gap:10px;margin-bottom:6px;">' +
    '<span style="font-size:15px;font-weight:700;">รายการแก้ไขที่บันทึก</span>' +
    '<span style="font-size:13px;color:var(--fg-2);">('+counts.all+')</span>' +
    '<svg style="margin-left:auto;" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--fg-3)" stroke-width="2"><path d="M9 18l6-6-6-6"></path></svg></div>';

  function sigSlot(role, label, dataUrl, name){
    var inner = dataUrl
      ? '<div class="sign-slot signed" style="'+styleUrl(dataUrl)+'"></div>'
      : '<div class="sign-slot tapopt" data-action="open-signature" data-role="'+role+'">แตะเพื่อเซ็นชื่อ</div>';
    var actions = dataUrl
      ? '<div style="display:flex;gap:14px;margin-top:8px;font-size:12.5px;">' +
          '<span class="tapopt" data-action="open-signature" data-role="'+role+'" style="color:var(--ap-red-600);font-weight:600;">เซ็นใหม่</span>' +
          '<span class="tapopt" data-action="remove-signature" data-role="'+role+'" style="color:var(--fg-3);">ลบลายเซ็น</span></div>'
      : '';
    return '<div class="sign-box"><div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:9px;">' +
      '<span style="font-size:13px;font-weight:700;">'+esc(label)+'</span>' +
      (name?'<span style="font-size:12px;color:var(--fg-2);">'+esc(name)+'</span>':'') + '</div>' + inner + actions + '</div>';
  }
  var signHtml = '<div style="font-size:15px;font-weight:700;margin:22px 0 12px;">ลายเซ็นกำกับใบงาน</div>' +
    '<div style="display:flex;flex-direction:column;gap:12px;">' +
      sigSlot('se','ผู้ตรวจ (SE)', S.sigSE, S.sigSEName || S.inspector) +
      sigSlot('cust', secondSignerLabel(S.mode), S.sigCust, S.sigCustName || (isHandover?U.customer:'')) +
    '</div>';

  return '<div class="screen">' +
    '<div class="topbar">' +
      '<div class="topbar-row">' +
        '<span class="tapopt back-link" data-action="back-unit" style="flex:1;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">'+IC_BACK+'</svg><span>'+esc(U.code)+'</span></span>' +
        iconBtn('open-overlay-sheet',' data-mode="edit" data-id="'+attr(S.id)+'"',IC_EDIT) +
        iconBtn('back-projects','',IC_HOME) +
      '</div>' +
      '<div style="display:flex;align-items:center;gap:9px;margin-top:12px;">' +
        '<h1 style="margin:0;">ครั้งที่ '+(S.round||1)+'</h1><span class="tag '+mm.tag+'">'+esc(mm.label)+'</span></div>' +
      '<div class="sub">'+(S.date?esc(S.date):'ยังไม่ระบุวันที่')+(S.inspector?' · ผู้ตรวจ '+esc(S.inspector):'')+'</div>' +
    '</div>' +
    '<div class="scroll" style="padding:16px;">' +
      '<button type="button" class="tapopt" data-action="export-pdf" data-scope="sheet" style="width:100%;margin-bottom:16px;display:flex;align-items:center;justify-content:center;gap:8px;background:#fff;border:1.5px solid var(--ap-red-600);color:var(--ap-red-600);border-radius:12px;padding:14px;font-size:15px;font-weight:700;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">'+IC_PDF+'</svg>ส่งออกรายงาน PDF</button>' +
      summary + listLink + signHtml +
    '</div>' +
    '<div class="bottom-bar">' +
      '<button type="button" class="btn-primary tapopt" data-action="open-overlay-defect" data-mode="add" style="flex:1;"><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">'+IC_PLUS+'</svg>บันทึก defect</button>' +
    '</div></div>';
}

/* ---------- screen: defect list (saved records, own page) ---------- */
function renderDefectListScreen(){
  var P = findProject(state.curP), U = findUnit(P, state.curU), S = findSheet(U, state.curS);
  if (!P || !U || !S){ state.screen='unit'; return renderUnitScreen(); }
  return '<div class="screen">' +
    '<div class="topbar">' +
      '<div class="topbar-row">' +
        '<span class="tapopt back-link" data-action="back-sheet" style="flex:1;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">'+IC_BACK+'</svg><span>ครั้งที่ '+(S.round||1)+'</span></span>' +
        iconBtn('back-projects','',IC_HOME) +
      '</div>' +
      '<h1 style="margin-top:12px;">รายการแก้ไขที่บันทึก</h1>' +
      '<div class="sub">'+esc(U.code)+' · '+S.defects.length+' รายการ</div>' +
    '</div>' +
    '<div class="scroll" style="padding:16px;">' + defectListHtml(S) + '</div>' +
    '<div class="bottom-bar">' +
      '<button type="button" class="btn-primary tapopt" data-action="open-overlay-defect" data-mode="add" style="flex:1;"><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">'+IC_PLUS+'</svg>บันทึก defect</button>' +
    '</div></div>';
}

/* ---------- overlay: project ---------- */
function renderProjectOverlay(){
  var isEdit = state.formMode==='edit';
  var P = isEdit ? findProject(state.editId) : null;
  var name = P?P.name:'', details = P?(P.details||''):'', curType = P?P.type:state.formType;
  var typeChips = TYPES.map(function(t){ return '<span class="chip tapopt'+(t===curType?' is-active':'')+'" data-group="type" data-value="'+attr(t)+'" data-action="pick-chip">'+esc(t)+'</span>'; }).join('');
  return '<div class="overlay-backdrop tapopt" data-action="close-overlay"></div>' +
  '<div class="overlay-sheet" id="project-overlay"><div class="sheet-grabber"></div>' +
    '<div style="font-size:20px;font-weight:700;margin-bottom:18px;">'+(isEdit?'แก้ไขโครงการ':'เพิ่มโครงการใหม่')+'</div>' +
    '<div class="field-label">ชื่อโครงการ</div>' +
    '<input class="fld" id="f-p-name" value="'+attr(name)+'" placeholder="เช่น THE PALAZZO พระราม 9" style="margin-bottom:16px;">' +
    '<div class="field-label">รายละเอียด / ที่ตั้ง (ถ้ามี)</div>' +
    '<textarea class="fld" id="f-p-details" rows="2" placeholder="เช่น ที่ตั้ง, เฟส, หมายเหตุโครงการ" style="margin-bottom:16px;">'+esc(details)+'</textarea>' +
    '<div class="field-label">ประเภทโครงการ</div>' +
    '<div class="chip-row" style="margin-bottom:22px;">'+typeChips+'</div>' +
    '<button type="button" class="btn-primary tapopt" data-action="submit-project">'+(isEdit?'บันทึกการแก้ไข':'สร้างโครงการ')+'</button></div>';
}

/* ---------- overlay: unit (แปลง) ---------- */
function renderUnitOverlay(){
  var P = findProject(state.curP);
  var isEdit = state.formMode==='edit';
  var U = isEdit ? findUnit(P, state.editId) : null;
  return '<div class="overlay-backdrop tapopt" data-action="close-overlay"></div>' +
  '<div class="overlay-sheet" id="unit-overlay"><div class="sheet-grabber"></div>' +
    '<div style="font-size:20px;font-weight:700;margin-bottom:18px;">'+(isEdit?'แก้ไขแปลง':'เพิ่มแปลง / บ้าน')+'</div>' +
    '<div class="field-label">ชื่อแปลง</div>' +
    '<input class="fld" id="f-u-plot" value="'+attr(U?U.plot||'':'')+'" placeholder="เช่น แปลง 00A01" style="margin-bottom:16px;">' +
    '<div class="field-label">บ้านเลขที่</div>' +
    '<input class="fld" id="f-u-code" value="'+attr(U?U.code:'')+'" placeholder="เช่น 9/14" style="margin-bottom:16px;">' +
    '<div class="field-label">แบบบ้าน (ถ้ามี)</div>' +
    '<input class="fld" id="f-u-model" value="'+attr(U?U.model||'':'')+'" placeholder="เช่น แบบ Grande" style="margin-bottom:16px;">' +
    '<div class="field-label">ชื่อลูกค้า (ถ้ามี)</div>' +
    '<input class="fld" id="f-u-customer" value="'+attr(U?U.customer||'':'')+'" placeholder="เช่น คุณสมชาย ใจดี" style="margin-bottom:16px;">' +
    '<div class="field-label">หมายเหตุ (ถ้ามี)</div>' +
    '<input class="fld" id="f-u-note" value="'+attr(U?U.note||'':'')+'" placeholder="เช่น บ้านว่างเกิน 1 ปี" style="margin-bottom:22px;">' +
    '<button type="button" class="btn-primary tapopt" data-action="submit-unit">'+(isEdit?'บันทึกการแก้ไข':'เพิ่มแปลง')+'</button></div>';
}

/* ---------- overlay: sheet (ใบงานตรวจ) ---------- */
function renderSheetOverlay(){
  var P = findProject(state.curP), U = findUnit(P, state.curU);
  var isEdit = state.formMode==='edit';
  var S = isEdit ? findSheet(U, state.editId) : null;
  var curMode = S ? S.mode : state.formSheetMode;
  var nextRound = 1; U.sheets.forEach(function(s){ if((s.round||0)>=nextRound) nextRound=(s.round||0)+1; });
  var round = S ? S.round : nextRound;
  var date = S ? (S.date||'') : todayStr();
  var inspector = S ? (S.inspector||'') : '';

  var modeDefs = [
    { id:'handover', title:'ตรวจรับบ้านก่อนโอน', desc:'เดินตรวจพร้อมลูกค้า · มีลายเซ็นลูกค้ากำกับ' },
    { id:'stock', title:'ปรับปรุงบ้าน Stock', desc:'สำรวจบ้านคงคลังเพื่อทำรายการซ่อม/ปรับปรุง' },
  ];
  var modeCards = modeDefs.map(function(m){
    return '<div class="mode-card tapopt'+(m.id===curMode?' is-active':'')+'" data-group="mode" data-value="'+m.id+'" data-action="pick-chip">' +
      '<span class="dot"><span></span></span><div><div class="mode-title">'+esc(m.title)+'</div><div class="mode-desc">'+esc(m.desc)+'</div></div></div>';
  }).join('');
  return '<div class="overlay-backdrop tapopt" data-action="close-overlay"></div>' +
  '<div class="overlay-sheet" id="sheet-overlay"><div class="sheet-grabber"></div>' +
    '<div style="font-size:20px;font-weight:700;margin-bottom:18px;">'+(isEdit?'แก้ไขใบงานตรวจ':'เพิ่มใบงานตรวจ')+'</div>' +
    '<div class="field-label">ประเภทงาน</div>' +
    '<div style="display:flex;flex-direction:column;gap:10px;margin-bottom:18px;">'+modeCards+'</div>' +
    '<div style="display:flex;gap:12px;margin-bottom:16px;">' +
      '<div style="width:110px;"><div class="field-label">ครั้งที่</div><input class="fld" id="f-s-round" type="number" min="1" inputmode="numeric" value="'+attr(round)+'"></div>' +
      '<div style="flex:1;"><div class="field-label">วันที่ตรวจ</div><input class="fld" id="f-s-date" value="'+attr(date)+'" placeholder="วว/ดด/ปปปป"></div>' +
    '</div>' +
    '<div class="field-label">ผู้ตรวจ (SE)</div>' +
    '<input class="fld" id="f-s-inspector" value="'+attr(inspector)+'" placeholder="เช่น decha" style="margin-bottom:22px;">' +
    '<button type="button" class="btn-primary tapopt" data-action="submit-sheet">'+(isEdit?'บันทึกการแก้ไข':'สร้างใบงานตรวจ')+'</button></div>';
}

/* ---------- overlay: defect ---------- */
function renderPhotoStripHtml(target){
  target = target || 'before';
  var bucket = target==='after' ? pendingPhotosAfter : pendingPhotos;
  var camBtns = '<div style="display:flex;gap:10px;">' +
    '<button type="button" class="tapopt" data-action="trigger-camera" data-target="'+target+'" style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;background:#fff;border:1px solid var(--border-default);border-radius:12px;padding:11px 10px;font-size:13px;font-weight:600;">' +
      '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3Z"></path><circle cx="12" cy="13" r="3.2"></circle></svg>ถ่ายรูป</button>' +
    '<button type="button" class="tapopt" data-action="trigger-gallery" data-target="'+target+'" style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;background:#fff;border:1px solid var(--border-default);border-radius:12px;padding:11px 10px;font-size:13px;font-weight:600;">' +
      '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.6"></circle><path d="m21 15-5-5L5 21"></path></svg>เลือกจากคลัง</button></div>';
  var tiles = bucket.map(function(ph, i){
    return '<div class="photo-tile" style="'+styleUrl(ph.url)+'"><span class="photo-remove tapopt" data-action="remove-photo" data-target="'+target+'" data-index="'+i+'"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M18 6 6 18M6 6l12 12"></path></svg></span></div>';
  }).join('');
  return camBtns + '<div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:12px;">'+tiles+'</div>' +
    (bucket.length>=MAX_PHOTOS_PER_DEFECT ? '<div style="font-size:11.5px;color:var(--fg-3);margin-top:6px;">ใส่รูปได้สูงสุด '+MAX_PHOTOS_PER_DEFECT+' รูปต่อรายการ</div>' : '');
}
function renderDefectOverlay(){
  var isEdit = state.formMode==='edit';
  var P = findProject(state.curP), U = findUnit(P, state.curU), S = findSheet(U, state.curS);
  var D = isEdit ? findDefect(S, state.editId) : null;
  var curCat = state.formCat, curSev = state.formSev, curRoom = state.formRoom, curStatus = state.formStatus||'open', note = state.formNoteDraft||'';
  var catChips = CATS.map(function(c){ return '<span class="chip tapopt'+(c.id===curCat?' is-active':'')+'" data-group="cat" data-value="'+c.id+'" data-action="pick-chip">'+esc(c.name)+'</span>'; }).join('') + '<span class="chip tapopt" data-action="add-cat" style="border-style:dashed;color:var(--ap-red-600);font-weight:600;">+ เพิ่มหมวด</span>';
  var sevChips = ['high','mid','low'].map(function(id){ return '<span class="sev-chip tapopt'+(id===curSev?' is-active':'')+'" data-group="sev" data-value="'+id+'" data-action="pick-chip">'+esc(SEV[id].name)+'</span>'; }).join('');
  var stChips = STATUS_ORDER.map(function(id){ return '<span class="st-chip tapopt'+(id===curStatus?' is-active':'')+'" data-group="status" data-value="'+id+'" data-action="pick-chip">'+esc(STATUS[id].name)+'</span>'; }).join('');
  var roomChips = ROOMS.map(function(r){ return '<span class="chip tapopt'+(r===curRoom?' is-active':'')+'" data-group="room" data-value="'+attr(r)+'" data-action="pick-chip">'+esc(r)+'</span>'; }).join('') + '<span class="chip tapopt" data-action="add-room" style="border-style:dashed;color:var(--ap-red-600);font-weight:600;">+ เพิ่มห้อง</span>';
  return '<div class="overlay-backdrop tapopt" data-action="close-overlay"></div>' +
  '<div class="overlay-sheet" id="defect-overlay"><div class="sheet-grabber"></div>' +
    '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">' +
      '<span style="font-size:20px;font-weight:700;">'+(isEdit?'แก้ไข defect':'บันทึก defect')+'</span>' +
      '<span class="tapopt icon-btn" data-action="close-overlay"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M18 6 6 18M6 6l12 12"></path></svg></span></div>' +
    '<div class="field-label">รูปก่อนแก้ไข</div>' +
    '<div id="defect-photo-strip-before" style="margin-bottom:16px;">'+renderPhotoStripHtml('before')+'</div>' +
    '<div class="field-label">รูปหลังแก้ไข (ถ้ามี)</div>' +
    '<div id="defect-photo-strip-after" style="margin-bottom:18px;">'+renderPhotoStripHtml('after')+'</div>' +
    '<div class="field-label">หมวดหมู่</div><div class="chip-row" style="margin-bottom:18px;">'+catChips+'</div>' +
    '<div class="field-label">ระดับความรุนแรง</div><div style="display:flex;gap:8px;margin-bottom:18px;">'+sevChips+'</div>' +
    '<div class="field-label">สถานะการแก้ไข</div><div style="display:flex;gap:8px;margin-bottom:18px;">'+stChips+'</div>' +
    '<div class="field-label">ห้อง / พื้นที่</div><div class="chip-row" style="margin-bottom:18px;">'+roomChips+'</div>' +
    '<div class="field-label">รายละเอียด</div>' +
    '<textarea class="fld" id="f-d-note" rows="3" placeholder="พิมพ์รายละเอียดที่พบ…" style="margin-bottom:20px;">'+esc(note)+'</textarea>' +
    '<button type="button" class="btn-primary tapopt" data-action="submit-defect">'+(isEdit?'บันทึกการแก้ไข':'บันทึก defect')+'</button></div>';
}
function refreshPhotoStrip(){
  ['before','after'].forEach(function(t){
    var el = document.getElementById('defect-photo-strip-'+t);
    if (el){ el.innerHTML = renderPhotoStripHtml(t); hydrateLazyPhotos(el); }
  });
}

/* ---------- overlay: signature pad ---------- */
function renderSettingsOverlay(){
  var closeX = '<span class="tapopt" data-action="close-overlay" style="width:36px;height:36px;border-radius:999px;display:flex;align-items:center;justify-content:center;background:var(--ap-neutral-200);color:var(--fg-2);"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M18 6 6 18M6 6l12 12"></path></svg></span>';
  return '<div class="overlay-backdrop tapopt" data-action="close-overlay"></div>' +
  '<div class="overlay-sheet" id="settings-overlay"><div class="sheet-grabber"></div>' +
    '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">' +
      '<span style="font-size:20px;font-weight:700;">ตั้งค่า</span>' + closeX + '</div>' +
    '<div class="card" style="padding:14px 16px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:center;">' +
      '<span style="font-size:14px;color:var(--fg-2);">เวอร์ชันแอป</span>' +
      '<b style="font-size:15px;font-variant-numeric:tabular-nums;">'+esc(APP_VERSION)+'</b></div>' +
    '<div style="font-size:15px;font-weight:700;margin-bottom:6px;">ข้อมูลสำรอง</div>' +
    '<div style="font-size:13px;color:var(--fg-2);line-height:1.55;margin-bottom:12px;">มี '+projects.length+' โครงการในเครื่อง · แนะนำให้สำรองข้อมูลเป็นไฟล์เก็บไว้ กันข้อมูลหายเมื่อเปลี่ยนเครื่อง ล้างเบราว์เซอร์ หรือถอนแอป</div>' +
    '<button type="button" class="btn-primary tapopt" data-action="export-backup"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 3v12"></path><path d="m8 11 4 4 4-4"></path><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"></path></svg>สำรองข้อมูล (ดาวน์โหลดไฟล์)</button>' +
    '<button type="button" class="btn-ghost tapopt" data-action="import-backup" style="margin-top:10px;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 15V3"></path><path d="m8 7 4-4 4 4"></path><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"></path></svg>กู้คืนข้อมูลจากไฟล์</button>' +
    '<div style="height:1px;background:var(--border-subtle);margin:20px 0;"></div>' +
    '<div style="font-size:13px;color:var(--fg-2);line-height:1.55;margin-bottom:14px;">ถ้าแอปไม่อัปเดตเป็นเวอร์ชันล่าสุด กดปุ่มด้านล่างเพื่อล้างแคชแล้วโหลดใหม่ · ข้อมูลที่บันทึกไว้จะยังอยู่ครบ</div>' +
    '<button type="button" class="btn-ghost tapopt" data-action="clear-cache"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M21 12a9 9 0 1 1-2.64-6.36"></path><path d="M21 3v6h-6"></path></svg>อัปเดต / ล้างแคช</button>' +
  '</div>';
}
function renderSignatureOverlay(){
  var P = findProject(state.curP), U = findUnit(P, state.curU), S = findSheet(U, state.curS);
  var label = state.sigRole==='cust' ? ('ลายเซ็น'+secondSignerLabel(S.mode)) : 'ลายเซ็นผู้ตรวจ (SE)';
  var nameVal = state.sigRole==='cust' ? (S.sigCustName||U.customer||'') : (S.sigSEName||S.inspector||'');
  return '<div class="overlay-backdrop tapopt" data-action="close-overlay"></div>' +
  '<div class="overlay-sheet" id="signature-overlay"><div class="sheet-grabber"></div>' +
    '<div style="font-size:20px;font-weight:700;margin-bottom:6px;">'+esc(label)+'</div>' +
    '<div style="font-size:13px;color:var(--fg-2);margin-bottom:14px;">เซ็นในกรอบด้านล่างด้วยนิ้วหรือปากกา</div>' +
    '<canvas id="sig-canvas"></canvas>' +
    '<div style="display:flex;justify-content:flex-end;margin:8px 0 16px;"><span class="tapopt" data-action="clear-signature" style="font-size:13px;font-weight:600;color:var(--ap-red-600);">ล้าง</span></div>' +
    '<div class="field-label">ชื่อผู้เซ็น (ถ้ามี)</div>' +
    '<input class="fld" id="f-sig-name" value="'+attr(nameVal)+'" placeholder="เช่น คุณสมชาย ใจดี" style="margin-bottom:20px;">' +
    '<button type="button" class="btn-primary tapopt" data-action="submit-signature">บันทึกลายเซ็น</button></div>';
}
function initSignaturePad(){
  var c = document.getElementById('sig-canvas'); if (!c) return;
  var rect = c.getBoundingClientRect();
  var dpr = window.devicePixelRatio || 1;
  c.width = Math.round(rect.width*dpr); c.height = Math.round(rect.height*dpr);
  var ctx = c.getContext('2d'); ctx.scale(dpr,dpr);
  ctx.lineWidth = 2.4; ctx.lineCap='round'; ctx.lineJoin='round'; ctx.strokeStyle='#131317';
  var drawing=false, last=null, dirty=false;
  function pos(e){ var r=c.getBoundingClientRect(); var t=(e.touches&&e.touches[0])||e; return { x:t.clientX-r.left, y:t.clientY-r.top }; }
  function down(e){ drawing=true; last=pos(e); e.preventDefault(); }
  function move(e){ if(!drawing) return; var p=pos(e); ctx.beginPath(); ctx.moveTo(last.x,last.y); ctx.lineTo(p.x,p.y); ctx.stroke(); last=p; dirty=true; e.preventDefault(); }
  function up(){ drawing=false; }
  if (window.PointerEvent){
    c.addEventListener('pointerdown',down); c.addEventListener('pointermove',move); window.addEventListener('pointerup',up);
  } else {
    c.addEventListener('touchstart',down,{passive:false}); c.addEventListener('touchmove',move,{passive:false}); window.addEventListener('touchend',up);
    c.addEventListener('mousedown',down); c.addEventListener('mousemove',move); window.addEventListener('mouseup',up);
  }
  sigPad = {
    isDirty:function(){ return dirty; },
    clear:function(){ ctx.clearRect(0,0,c.width,c.height); dirty=false; },
    export:function(){
      // trim to a max width and add white background for a clean PNG
      var W=520, sc=W/c.width, out=document.createElement('canvas');
      out.width=W; out.height=Math.round(c.height*sc);
      var o=out.getContext('2d'); o.fillStyle='#fff'; o.fillRect(0,0,out.width,out.height);
      o.drawImage(c,0,0,out.width,out.height);
      return out.toDataURL('image/png');
    }
  };
}

/* ---------- navigation ---------- */
function gotoProjects(){ Object.assign(state,{screen:'projects',curP:null,curU:null,curS:null,overlay:null}); render(); }
function gotoProject(pid){ Object.assign(state,{screen:'project',curP:pid,curU:null,curS:null,overlay:null}); render(); }
function gotoUnit(uidv){ Object.assign(state,{screen:'unit',curU:uidv,curS:null,overlay:null}); render(); }
function gotoSheet(sid){ Object.assign(state,{screen:'sheet',curS:sid,overlay:null}); render(); }
function backToProject(){ Object.assign(state,{screen:'project',curU:null,curS:null,overlay:null}); render(); }
function backToUnit(){ Object.assign(state,{screen:'unit',curS:null,overlay:null}); render(); }
function gotoDefectList(){ Object.assign(state,{screen:'deflist',overlay:null}); render(); }
function backToSheet(){ Object.assign(state,{screen:'sheet',overlay:null}); render(); }

function openProjectOverlay(mode,id){ state.overlay='project'; state.formMode=mode; state.editId=id||null; if(mode!=='edit') state.formType=TYPES[0]; render(); }
function openUnitOverlay(mode,id){ state.overlay='unit'; state.formMode=mode; state.editId=id||null; render(); }
function openSheetOverlay(mode,id){ state.overlay='sheet'; state.formMode=mode; state.editId=id||null; if(mode!=='edit') state.formSheetMode='handover'; render(); }
function openDefectOverlay(mode,id){
  state.overlay='defect'; state.formMode=mode; state.editId=id||null;
  state.formCat=CATS[0].id; state.formSev='mid'; state.formRoom=ROOMS[0]; state.formNoteDraft=''; state.formStatus='open';
  if (mode==='edit'){
    var P=findProject(state.curP),U=findUnit(P,state.curU),S=findSheet(U,state.curS),D=findDefect(S,id);
    pendingPhotos=[]; pendingPhotosAfter=[];
    if (D){
      state.formCat=D.cat; state.formSev=D.sev; state.formRoom=D.room; state.formNoteDraft=D.note||''; state.formStatus=D.status||'open';
      function loadSet(ids){ return Promise.all((ids||[]).map(function(pid){ return Photos.get(pid).then(function(url){ return {url:url,photoId:pid}; }); })); }
      Promise.all([loadSet(D.photoIds), loadSet(D.photoIdsAfter)]).then(function(res){
        pendingPhotos=res[0].filter(function(x){return x.url;});
        pendingPhotosAfter=res[1].filter(function(x){return x.url;});
        render();
      });
    }
  } else { pendingPhotos=[]; pendingPhotosAfter=[]; }
  render();
}
function openSignature(role){ state.overlay='signature'; state.sigRole=role; sigPad=null; render(); }
function openSettings(){ state.overlay='settings'; render(); }
function clearAppCache(){
  if(!window.confirm('อัปเดตแอปเป็นเวอร์ชันล่าสุด? (ล้างแคช · ข้อมูลที่บันทึกไว้จะยังอยู่ครบ)')) return;
  var done=function(){ try{ location.reload(); }catch(e){ location.href=location.href; } };
  try{
    var tasks=[];
    if(window.caches && caches.keys){ tasks.push(caches.keys().then(function(keys){ return Promise.all(keys.map(function(k){ return caches.delete(k); })); })); }
    if('serviceWorker' in navigator && navigator.serviceWorker.getRegistrations){ tasks.push(navigator.serviceWorker.getRegistrations().then(function(rs){ return Promise.all(rs.map(function(r){ return r.unregister(); })); })); }
    Promise.all(tasks).then(done).catch(done);
  }catch(e){ done(); }
}
function collectPhotoIds(){
  var ids={};
  projects.forEach(function(p){ (p.units||[]).forEach(function(u){ (u.sheets||[]).forEach(function(s){ (s.defects||[]).forEach(function(d){ (d.photoIds||[]).forEach(function(x){ ids[x]=1; }); (d.photoIdsAfter||[]).forEach(function(x){ ids[x]=1; }); }); }); }); });
  return Object.keys(ids);
}
function readList(key){ try{ return JSON.parse(localStorage.getItem(key)||'[]')||[]; }catch(e){ return []; } }
function exportBackup(){
  var ids=collectPhotoIds();
  Promise.all(ids.map(function(id){ return Photos.get(id).then(function(u){ return [id,u]; }); })).then(function(entries){
    var photos={}; entries.forEach(function(e){ if(e[1]) photos[e[0]]=e[1]; });
    var data={ app:'ap-inspect', schema:'v4', version:APP_VERSION, exportedAt:new Date().toISOString(),
      projects:projects, photos:photos, cats:readList(CAT_KEY), rooms:readList(ROOM_KEY) };
    var blob=new Blob([JSON.stringify(data)],{type:'application/json'});
    var url=URL.createObjectURL(blob), a=document.createElement('a');
    var d=new Date(), pad=function(n){ return (n<10?'0':'')+n; };
    a.href=url; a.download='ap-inspect-backup-'+d.getFullYear()+pad(d.getMonth()+1)+pad(d.getDate())+'-'+pad(d.getHours())+pad(d.getMinutes())+'.json';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    setTimeout(function(){ URL.revokeObjectURL(url); }, 1500);
  });
}
function importBackupFile(file){
  if(!file) return;
  var reader=new FileReader();
  reader.onload=function(){
    var data; try{ data=JSON.parse(reader.result); }catch(e){ window.alert('ไฟล์สำรองไม่ถูกต้อง (อ่านไม่ได้)'); return; }
    if(!data || data.app!=='ap-inspect' || !Array.isArray(data.projects)){ window.alert('ไฟล์นี้ไม่ใช่ไฟล์สำรองของแอปนี้'); return; }
    if(!window.confirm('กู้คืนข้อมูลจากไฟล์นี้? ข้อมูลปัจจุบันทั้งหมดในเครื่องจะถูกแทนที่')) return;
    var photos=data.photos||{}, pids=Object.keys(photos);
    Promise.all(pids.map(function(id){ return Photos.putId(id, photos[id]); })).then(function(){
      projects = data.projects; Store.save(projects);
      try{ if(Array.isArray(data.cats)) localStorage.setItem(CAT_KEY, JSON.stringify(data.cats)); }catch(e){}
      try{ if(Array.isArray(data.rooms)) localStorage.setItem(ROOM_KEY, JSON.stringify(data.rooms)); }catch(e){}
      if(photoUrlCache && photoUrlCache.clear) photoUrlCache.clear();
      loadCustomLists();
      Object.assign(state,{overlay:null,screen:'projects',curP:null,curU:null,curS:null});
      render();
      window.alert('กู้คืนข้อมูลสำเร็จ · '+projects.length+' โครงการ');
    });
  };
  reader.readAsText(file);
}
function closeOverlay(){ state.overlay=null; pendingPhotos=[]; pendingPhotosAfter=[]; sigPad=null; render(); }

/* ---------- mutations ---------- */
function submitProjectForm(){
  var nameEl=document.getElementById('f-p-name'), name=nameEl.value.trim();
  if(!name){ nameEl.focus(); nameEl.style.borderColor='var(--ap-red-600)'; return; }
  var details=document.getElementById('f-p-details').value.trim();
  var typeChip=document.querySelector('#project-overlay [data-group="type"].is-active');
  var type=typeChip?typeChip.getAttribute('data-value'):TYPES[0];
  if(state.formMode==='edit'){ var P=findProject(state.editId); if(P){ P.name=name; P.details=details; P.type=type; } persist(); state.overlay=null; render(); }
  else { var np={id:uid(),name:name,details:details,type:type,units:[],createdAt:Date.now()}; projects.unshift(np); persist(); Object.assign(state,{overlay:null,screen:'project',curP:np.id}); render(); }
}
function submitUnitForm(){
  var P=findProject(state.curP);
  var codeEl=document.getElementById('f-u-code'), code=codeEl.value.trim();
  if(!code){ codeEl.focus(); codeEl.style.borderColor='var(--ap-red-600)'; return; }
  var plot=(document.getElementById('f-u-plot')||{value:''}).value.trim();
  var model=(document.getElementById('f-u-model')||{value:''}).value.trim();
  var customer=(document.getElementById('f-u-customer')||{value:''}).value.trim();
  var note=(document.getElementById('f-u-note')||{value:''}).value.trim();
  if(state.formMode==='edit'){ var U=findUnit(P,state.editId); if(U){ U.code=code; U.plot=plot; U.model=model; U.customer=customer; U.note=note; } }
  else { P.units.push({id:uid(),code:code,plot:plot,model:model,customer:customer,note:note,sheets:[],createdAt:Date.now()}); }
  persist(); state.overlay=null; render();
}
function submitSheetForm(){
  var P=findProject(state.curP), U=findUnit(P,state.curU);
  var modeCard=document.querySelector('#sheet-overlay [data-group="mode"].is-active');
  var mode=modeCard?modeCard.getAttribute('data-value'):'handover';
  var round=parseInt((document.getElementById('f-s-round')||{value:'1'}).value,10)||1;
  var date=(document.getElementById('f-s-date')||{value:''}).value.trim();
  var inspector=(document.getElementById('f-s-inspector')||{value:''}).value.trim();
  if(state.formMode==='edit'){ var S=findSheet(U,state.editId); if(S){ S.mode=mode; S.round=round; S.date=date; S.inspector=inspector; } persist(); state.overlay=null; render(); }
  else { var ns=newSheet(mode,round,{date:date,inspector:inspector}); U.sheets.push(ns); persist(); Object.assign(state,{overlay:null,screen:'sheet',curS:ns.id}); render(); }
}
function submitDefectForm(){
  var P=findProject(state.curP),U=findUnit(P,state.curU),S=findSheet(U,state.curS);
  var catChip=document.querySelector('#defect-overlay [data-group="cat"].is-active');
  var sevChip=document.querySelector('#defect-overlay [data-group="sev"].is-active');
  var roomChip=document.querySelector('#defect-overlay [data-group="room"].is-active');
  var statusChip=document.querySelector('#defect-overlay [data-group="status"].is-active');
  var note=document.getElementById('f-d-note').value.trim() || '(ไม่มีรายละเอียด)';
  var cat=catChip?catChip.getAttribute('data-value'):CATS[0].id;
  var sev=sevChip?sevChip.getAttribute('data-value'):'mid';
  var room=roomChip?roomChip.getAttribute('data-value'):ROOMS[0];
  var status=statusChip?statusChip.getAttribute('data-value'):'open';
  var now=new Date().toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'});
  function resolveSet(list){ return Promise.all(list.map(function(ph){ return ph.photoId?Promise.resolve(ph.photoId):Photos.put(ph.url).then(function(id){ photoUrlCache.set(id,ph.url); return id; }); })); }
  Promise.all([resolveSet(pendingPhotos), resolveSet(pendingPhotosAfter)])
    .then(function(res){
      var photoIds=res[0], photoIdsAfter=res[1];
      if(state.formMode==='edit'){ var D=findDefect(S,state.editId); if(D){ D.cat=cat; D.sev=sev; D.room=room; D.status=status; D.note=note; D.photoIds=photoIds; D.photoIdsAfter=photoIdsAfter; } }
      else { S.defects.push({id:uid(),room:room,cat:cat,sev:sev,status:status,note:note,photoIds:photoIds,photoIdsAfter:photoIdsAfter,time:now,createdAt:Date.now()}); }
      persist(); state.overlay=null; pendingPhotos=[]; pendingPhotosAfter=[]; render();
    });
}
function submitSignature(){
  var P=findProject(state.curP),U=findUnit(P,state.curU),S=findSheet(U,state.curS);
  if(!S) return;
  var name=(document.getElementById('f-sig-name')||{value:''}).value.trim();
  var dataUrl = (sigPad && sigPad.isDirty()) ? sigPad.export() : null;
  if(!dataUrl && !((state.sigRole==='cust'?S.sigCust:S.sigSE))){ alert('กรุณาเซ็นชื่อก่อนบันทึก'); return; }
  if(state.sigRole==='cust'){ if(dataUrl) S.sigCust=dataUrl; S.sigCustName=name; }
  else { if(dataUrl) S.sigSE=dataUrl; S.sigSEName=name; }
  persist(); state.overlay=null; sigPad=null; render();
}
function removeSignature(role){
  var P=findProject(state.curP),U=findUnit(P,state.curU),S=findSheet(U,state.curS); if(!S) return;
  if(role==='cust'){ S.sigCust=null; S.sigCustName=''; } else { S.sigSE=null; S.sigSEName=''; }
  persist(); render();
}
function cycleDefectStatus(did){
  var P=findProject(state.curP),U=findUnit(P,state.curU),S=findSheet(U,state.curS),D=findDefect(S,did);
  if(!D) return; D.status=STATUS_ORDER[(STATUS_ORDER.indexOf(D.status)+1)%STATUS_ORDER.length]; persist(); render();
}
function removeDefect(did){
  var P=findProject(state.curP),U=findUnit(P,state.curU),S=findSheet(U,state.curS); if(!S) return;
  var D=findDefect(S,did); if(D){ (D.photoIds||[]).forEach(function(id){ Photos.del(id); }); (D.photoIdsAfter||[]).forEach(function(id){ Photos.del(id); }); }
  S.defects=S.defects.filter(function(d){ return d.id!==did; }); persist(); render();
}
function removeSheet(sid){
  var P=findProject(state.curP),U=findUnit(P,state.curU); if(!U) return;
  var S=findSheet(U,sid);
  if(S){ (S.defects||[]).forEach(function(d){ (d.photoIds||[]).forEach(function(id){ Photos.del(id); }); (d.photoIdsAfter||[]).forEach(function(id){ Photos.del(id); }); }); }
  U.sheets=U.sheets.filter(function(s){ return s.id!==sid; }); persist(); state.screen='unit'; state.curS=null; render();
}
function captureDefectForm(){
  var c=document.querySelector('#defect-overlay [data-group="cat"].is-active');
  var s=document.querySelector('#defect-overlay [data-group="sev"].is-active');
  var r=document.querySelector('#defect-overlay [data-group="room"].is-active');
  var st=document.querySelector('#defect-overlay [data-group="status"].is-active');
  var n=document.getElementById('f-d-note');
  if(c) state.formCat=c.getAttribute('data-value');
  if(s) state.formSev=s.getAttribute('data-value');
  if(r) state.formRoom=r.getAttribute('data-value');
  if(st) state.formStatus=st.getAttribute('data-value');
  if(n) state.formNoteDraft=n.value;
}
function addCategory(){
  captureDefectForm();
  var name=(window.prompt('ชื่อหมวดหมู่ใหม่')||'').trim(); if(!name) return;
  var id='c'+uid(); CATS.push({id:id,name:name});
  try{ var a=JSON.parse(localStorage.getItem(CAT_KEY)||'[]'); a.push({id:id,name:name}); localStorage.setItem(CAT_KEY,JSON.stringify(a)); }catch(e){}
  state.formCat=id; render();
}
function addRoom(){
  captureDefectForm();
  var name=(window.prompt('ชื่อห้อง / พื้นที่ใหม่')||'').trim(); if(!name) return;
  if(ROOMS.indexOf(name)<0){ ROOMS.push(name); try{ var a=JSON.parse(localStorage.getItem(ROOM_KEY)||'[]'); a.push(name); localStorage.setItem(ROOM_KEY,JSON.stringify(a)); }catch(e){} }
  state.formRoom=name; render();
}
function moveDefect(did,dir){
  var P=findProject(state.curP),U=findUnit(P,state.curU),S=findSheet(U,state.curS); if(!S) return;
  var i=S.defects.findIndex(function(d){return d.id===did;}), j=dir==='up'?i-1:i+1;
  if(i<0||j<0||j>=S.defects.length) return; var t=S.defects[i]; S.defects[i]=S.defects[j]; S.defects[j]=t; persist(); render();
}
function addFilesAsPhotos(fileList){
  var files=Array.prototype.slice.call(fileList||[]); if(!files.length) return;
  var bucket = state.photoTarget==='after' ? pendingPhotosAfter : pendingPhotos;
  files=files.slice(0,Math.max(0,MAX_PHOTOS_PER_DEFECT-bucket.length));
  Promise.all(files.map(downscalePhoto)).then(function(urls){ urls.forEach(function(u){ if(u) bucket.push({url:u,photoId:null}); }); refreshPhotoStrip(); });
}

/* ---------- PDF / report ---------- */
function buildReportHtml(P, U, sheets, urlMap, sigMap){
  var RSTAT = {
    open:{ name:'เปิดงาน', color:'#921C1E', bg:'#FAEBEB' },
    prog:{ name:'กำลังแก้ไข', color:'#9B6612', bg:'#F6ECD6' },
    done:{ name:'ปิดงาน', color:'#1E7A3D', bg:'#CDEBD5' }
  };
  function photoCell(ids){
    if(!ids||!ids.length) return '<span class="noimg">—</span>';
    var shown = ids.slice(0,2).map(function(id){ var u=urlMap.get(id); return u?'<img src="'+u+'" class="pimg">':''; }).join('');
    var more = ids.length>2 ? '<div class="pmore">+'+(ids.length-2)+' รูป</div>' : '';
    return '<div class="pcell">'+shown+more+'</div>';
  }
  function sevSummary(ds){
    var c={high:0,mid:0,low:0}; ds.forEach(function(d){ if(c[d.sev]!=null) c[d.sev]++; });
    var parts=[]; if(c.high) parts.push('ร้ายแรง '+c.high); if(c.mid) parts.push('ปานกลาง '+c.mid); if(c.low) parts.push('เล็กน้อย '+c.low);
    return parts.length?' ('+parts.join(' · ')+')':'';
  }
  function infoItem(label, val, big){
    return '<div class="ii'+(big?' big':'')+'"><span>'+esc(label)+'</span><b>'+(val?esc(val):'<i class="blank"></i>')+'</b></div>';
  }

  var sections = sheets.map(function(S){
    var mm=modeMeta(S.mode), ds=S.defects||[];
    var counts={ all:ds.length, done:ds.filter(function(d){return d.status==='done';}).length };
    var closed = counts.all>0 && counts.done===counts.all;
    var stamp = closed ? '<div class="stamp">เอกสารปิดแล้ว</div>' : '';

    var rows = ds.map(function(d,i){
      var rs=RSTAT[d.status]||RSTAT.open, sev=SEV[d.sev];
      return '<tr>' +
        '<td class="c">'+(i+1)+'</td>' +
        '<td><div class="rm">'+esc(d.room)+' / '+esc(catName(d.cat))+' (#'+(i+1)+')</div>' +
          '<div class="dt">รายละเอียด : '+esc(d.note)+'</div>' +
          '<div class="sv" style="color:'+sev.color+'">● '+esc(sev.name)+'</div></td>' +
        '<td class="c"><span class="st" style="color:'+rs.color+';background:'+rs.bg+';">'+esc(rs.name)+'</span></td>' +
        '<td class="pc">'+photoCell(d.photoIds)+'</td>' +
        '<td class="pc">'+photoCell(d.photoIdsAfter)+'</td>' +
      '</tr>';
    }).join('') || '<tr><td colspan="5" style="text-align:center;color:#9C9CA4;padding:16px;">ไม่มี defect</td></tr>';

    var info = '<div class="info">' +
      infoItem('เลขที่เอกสาร', '') +
      infoItem('ประเภทงาน', mm.work) +
      infoItem('วันที่ตรวจสอบ', (S.date||'—')+' (ครั้งที่ '+(S.round||1)+')') +
      infoItem('โครงการ', P.name) +
      infoItem('ประเภทการตรวจ', mm.label) +
      infoItem('แปลง', U.plot, true) +
      infoItem('บ้านเลขที่', U.code, true) +
      infoItem('แบบบ้าน', U.model) +
      infoItem('ลูกค้า', U.customer) +
      infoItem('เจ้าหน้าที่', S.inspector) +
      infoItem('จำนวน Defect', counts.all+' รายการ'+sevSummary(ds)) +
    '</div>';

    var sigSE = sigMap.get(S.id+':se');
    var sigCust = sigMap.get(S.id+':cust');
    function sbox(url,name,role){
      var img = url ? '<img src="'+url+'" style="max-height:52px;">' : '';
      var line = url ? '' : '<div class="sline"></div>';
      return '<div class="sbox">'+img+line+'<div class="srole">'+esc(role)+(name?' · '+esc(name):'')+'</div></div>';
    }
    var signs = '<div class="signs">' + sbox(sigSE, S.sigSEName||S.inspector, 'ผู้ตรวจ (SE)') +
      sbox(sigCust, S.sigCustName||(S.mode==='stock'?'':U.customer), secondSignerLabel(S.mode)) + '</div>';

    return '<section class="sheet">' +
      '<div class="rhead">'+stamp +
        '<h1>QC Inspect Report</h1>' +
        '<div class="rsub">รายการงานที่ต้องแก้ไข (Defect List)</div></div>' +
      info +
      '<table><thead>' +
        '<tr><th class="c" rowspan="2" style="width:34px;">ลำดับ</th><th rowspan="2">รายการแจ้งซ่อม</th><th class="c" rowspan="2" style="width:62px;">สถานะ</th><th class="c" colspan="2">รูปถ่าย</th></tr>' +
        '<tr><th class="c" style="width:150px;">ก่อน</th><th class="c" style="width:150px;">หลัง</th></tr>' +
      '</thead><tbody>'+rows+'</tbody></table>' +
      signs +
    '</section>';
  }).join('');

  var css='@page{size:A4;margin:12mm 10mm;}*{box-sizing:border-box;}' +
    'body{font-family:"AP","Sarabun","Noto Sans Thai",-apple-system,sans-serif;color:#131317;margin:0;font-size:12px;}' +
    '.sheet{page-break-after:always;position:relative;}.sheet:last-child{page-break-after:auto;}' +
    '.rhead{text-align:center;position:relative;padding-bottom:12px;margin-bottom:14px;border-bottom:2px solid #131317;}' +
    '.rhead h1{font-size:21px;margin:0;font-weight:800;}.rsub{font-size:13px;font-weight:700;margin-top:3px;}' +
    '.stamp{position:absolute;top:-4px;right:0;border:2px dashed #2F9E52;color:#2F9E52;font-size:17px;font-weight:800;padding:5px 14px;border-radius:6px;transform:rotate(-5deg);}' +
    '.info{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px 22px;margin-bottom:16px;}' +
    '.ii span{font-size:10px;color:#70707A;margin-right:4px;}.ii b{font-size:12px;font-weight:600;}' +
    '.ii .blank{display:inline-block;width:120px;border-bottom:1px dotted #9C9CA4;height:12px;}' +
    '.ii.big b{font-size:16px;font-weight:700;}.ii.big span{font-size:11px;}' +
    'table{width:100%;border-collapse:collapse;font-size:11px;}' +
    'thead{display:table-header-group;}tr{page-break-inside:avoid;}' +
    'th{background:#EDEBE4;color:#131317;padding:7px 8px;font-weight:700;border:1px solid #C9C6BC;text-align:left;}' +
    'td{padding:8px;border:1px solid #D8D5CC;vertical-align:top;}td.c,th.c{text-align:center;}' +
    '.rm{font-weight:700;margin-bottom:4px;line-height:1.35;}.dt{color:#4A4A52;line-height:1.45;margin-bottom:4px;}.sv{font-size:10px;font-weight:700;}' +
    '.st{display:inline-block;font-weight:700;border-radius:6px;padding:3px 9px;font-size:11px;white-space:nowrap;}' +
    '.pc{width:150px;padding:6px;}.pcell{display:flex;flex-direction:column;gap:5px;align-items:center;}' +
    '.pimg{width:100%;max-width:150px;height:auto;max-height:180px;object-fit:cover;border-radius:5px;border:1px solid #E0DDD4;display:block;}' +
    '.pmore{font-size:10px;color:#4A4A52;font-weight:700;}.noimg{color:#C9C6BC;display:block;text-align:center;}' +
    '.signs{display:flex;gap:48px;margin-top:30px;page-break-inside:avoid;}.sbox{flex:1;text-align:center;}.sbox img{margin:0 auto 4px;}.sline{border-bottom:1px solid #131317;height:44px;margin-bottom:6px;}.srole{font-size:11px;color:#4A4A52;border-top:1px solid #131317;padding-top:5px;}' +
    '@media screen{body{background:#EAE8E2;}.wrap{max-width:900px;margin:22px auto;}.sheet{background:#fff;padding:30px 32px;margin-bottom:20px;box-shadow:0 8px 26px rgba(0,0,0,.14);}.ph{position:fixed;top:14px;right:14px;background:#921C1E;color:#fff;padding:11px 17px;border-radius:999px;font:600 13px sans-serif;cursor:pointer;border:0;z-index:9;}}' +
    '@media print{.ph{display:none;}}';

  var scriptTag='<scr'+'ipt>window.addEventListener("load",function(){setTimeout(function(){window.print();},500);});</scr'+'ipt>';
  return '<!DOCTYPE html><html lang="th"><head><meta charset="utf-8"><title>รายงานตรวจบ้าน · '+esc(P.name)+' · '+esc(U.code)+'</title><style>'+css+'</style></head><body><div class="wrap">'+sections+'</div><button class="ph" onclick="window.print()">พิมพ์ / บันทึก PDF</button>'+scriptTag+'</body></html>';
}
function exportPDF(scope){
  var P=findProject(state.curP), U=findUnit(P,state.curU);
  if(!P||!U) return;
  var sheets = scope==='sheet' ? [findSheet(U,state.curS)].filter(Boolean) : (U.sheets||[]).slice().sort(function(a,b){return (a.round||0)-(b.round||0);});
  if(!sheets.length) return;
  var w = window.open('','_blank');
  var idSet = new Set();
  sheets.forEach(function(s){ (s.defects||[]).forEach(function(d){ (d.photoIds||[]).forEach(function(id){ idSet.add(id); }); (d.photoIdsAfter||[]).forEach(function(id){ idSet.add(id); }); }); });
  var sigMap = new Map();
  sheets.forEach(function(s){ if(s.sigSE) sigMap.set(s.id+':se', s.sigSE); if(s.sigCust) sigMap.set(s.id+':cust', s.sigCust); });
  Promise.all(Array.from(idSet).map(function(id){ return Photos.get(id).then(function(url){ return [id,url]; }); }))
    .then(function(entries){
      var urlMap = new Map(entries.filter(function(e){ return e[1]; }));
      var html = buildReportHtml(P, U, sheets, urlMap, sigMap);
      if(w){ w.document.open(); w.document.write(html); w.document.close(); }
    })
    .catch(function(){ if(w) w.close(); });
}

/* ---------- event delegation ---------- */
document.getElementById('app').addEventListener('click', function(e){
  var el=e.target.closest('[data-action]'); if(!el) return;
  var a=el.getAttribute('data-action');
  switch(a){
    case 'open-project': gotoProject(el.getAttribute('data-id')); break;
    case 'open-unit': gotoUnit(el.getAttribute('data-id')); break;
    case 'open-sheet': gotoSheet(el.getAttribute('data-id')); break;
    case 'open-deflist': gotoDefectList(); break;
    case 'back-sheet': backToSheet(); break;
    case 'back-projects': gotoProjects(); break;
    case 'back-project': backToProject(); break;
    case 'back-unit': backToUnit(); break;
    case 'open-overlay-project': openProjectOverlay(el.getAttribute('data-mode'), el.getAttribute('data-id')); break;
    case 'open-overlay-unit': openUnitOverlay(el.getAttribute('data-mode'), el.getAttribute('data-id')); break;
    case 'open-overlay-sheet': openSheetOverlay(el.getAttribute('data-mode'), el.getAttribute('data-id')); break;
    case 'open-overlay-defect': openDefectOverlay(el.getAttribute('data-mode'), el.getAttribute('data-id')); break;
    case 'open-signature': openSignature(el.getAttribute('data-role')); break;
    case 'open-settings': openSettings(); break;
    case 'clear-cache': clearAppCache(); break;
    case 'export-backup': exportBackup(); break;
    case 'import-backup': document.getElementById('backup-input').click(); break;
    case 'clear-signature': if(sigPad) sigPad.clear(); break;
    case 'remove-signature': removeSignature(el.getAttribute('data-role')); break;
    case 'close-overlay': closeOverlay(); break;
    case 'pick-chip': { var g=el.getAttribute('data-group'), parent=el.parentElement; parent.querySelectorAll('[data-group="'+g+'"]').forEach(function(s){ s.classList.remove('is-active'); }); el.classList.add('is-active'); break; }
    case 'submit-project': submitProjectForm(); break;
    case 'submit-unit': submitUnitForm(); break;
    case 'submit-sheet': submitSheetForm(); break;
    case 'submit-defect': submitDefectForm(); break;
    case 'submit-signature': submitSignature(); break;
    case 'cycle-status': cycleDefectStatus(el.getAttribute('data-id')); break;
    case 'remove-defect': if(window.confirm('ลบ defect นี้ใช่หรือไม่?')) removeDefect(el.getAttribute('data-id')); break;
    case 'move-defect': moveDefect(el.getAttribute('data-id'), el.getAttribute('data-dir')); break;
    case 'remove-sheet': if(window.confirm('ลบใบงานตรวจนี้ทั้งหมดใช่หรือไม่? (ลบ defect และรูปทั้งหมดในใบงาน)')) removeSheet(el.getAttribute('data-id')); break;
    case 'add-cat': addCategory(); break;
    case 'add-room': addRoom(); break;
    case 'export-pdf': exportPDF(el.getAttribute('data-scope')); break;
    case 'trigger-camera': state.photoTarget=el.getAttribute('data-target')||'before'; document.getElementById('cam-input').click(); break;
    case 'trigger-gallery': state.photoTarget=el.getAttribute('data-target')||'before'; document.getElementById('gal-input').click(); break;
    case 'remove-photo': { var pt=el.getAttribute('data-target')||'before'; (pt==='after'?pendingPhotosAfter:pendingPhotos).splice(parseInt(el.getAttribute('data-index'),10),1); refreshPhotoStrip(); break; }
    default: break;
  }
});
document.getElementById('cam-input').addEventListener('change', function(e){ addFilesAsPhotos(e.target.files); e.target.value=''; });
document.getElementById('gal-input').addEventListener('change', function(e){ addFilesAsPhotos(e.target.files); e.target.value=''; });
document.getElementById('backup-input').addEventListener('change', function(e){ importBackupFile(e.target.files[0]); e.target.value=''; });

/* ---------- PWA registration ---------- */
function registerPWA(){
  try { if('serviceWorker' in navigator && (location.protocol==='https:' || location.hostname==='localhost')) navigator.serviceWorker.register('sw.js').catch(function(){}); } catch(e){}
}

/* ---------- boot ---------- */
migrate().then(function(loaded){ projects = loaded || []; loadCustomLists(); render(); registerPWA(); });
</script>
</body>
</html>
